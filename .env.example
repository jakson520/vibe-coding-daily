DATABASE_URL="file:./dev.db"

# AI 摘要。留空时会使用本地降级摘要，MVP 仍可运行。
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"

# 可选：提高 GitHub API 限额。
GITHUB_TOKEN=""

# 可选：邮件推送。未配置时只生成日报，不发送邮件。
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
EMAIL_TO=""

# 可选：保护手动触发接口 /api/jobs/daily。
DAILY_JOB_TOKEN="replace-with-a-local-token"
