generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Source {
  id         String    @id @default(cuid())
  name       String    @unique
  type       String
  url        String
  config     String    @default("{}")
  trustScore    Float     @default(0.7)
  enabled       Boolean   @default(true)
  lastFetchedAt DateTime?
  lastStatus    String    @default("skipped")
  lastError     String?
  fetchedCount  Int       @default(0)
  acceptedCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  articles      Article[]
}

model Article {
  id               String            @id @default(cuid())
  sourceId         String
  externalId       String
  title            String
  url              String
  author           String?
  publishedAt      DateTime?
  rawSummary       String?
  heat             Float             @default(0)
  qualityScore     Float             @default(0)
  contentHash      String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  source           Source            @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  analysis         ArticleAnalysis?
  tags             ArticleTag[]
  dailyReportItems DailyReportItem[]
  favorites        Favorite[]

  @@unique([sourceId, externalId])
  @@index([publishedAt])
  @@index([heat])
}

model ArticleAnalysis {
  id               String   @id @default(cuid())
  articleId        String   @unique
  summaryZh        String
  contentType      String
  whyItMatters     String
  relevanceScore   Float    @default(0)
  freshnessScore   Float    @default(0)
  credibilityScore Float    @default(0)
  heatScore        Float    @default(0)
  finalScore       Float    @default(0)
  aiModel          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([contentType])
  @@index([finalScore])
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  articles  ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model DailyReport {
  id            String            @id @default(cuid())
  reportDate    String            @unique
  title         String
  brief         String
  actionAdvice  String
  emailSentAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         DailyReportItem[]
}

model DailyReportItem {
  id        String      @id @default(cuid())
  reportId  String
  articleId String
  section   String
  rank      Int
  createdAt DateTime    @default(now())
  report    DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  article   Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([reportId, articleId])
  @@index([section, rank])
}

model Favorite {
  id        String   @id @default(cuid())
  articleId String   @unique
  note      String?
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}
